# sbe-jira-ui 설정 파일
# 이 파일을 .env 로 복사한 뒤 실제 값을 입력하세요.
# cp .env.example .env

# ── Gemini 설정 ─────────────────────────────
# Google AI Studio에서 발급: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# 사용할 Gemini 모델 (기본값: gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# ── Jira 설정 ────────────────────────────────
# Jira 프로필 → 보안 → 개인 액세스 토큰에서 발급
# https://jira.sinc.co.kr/profile
JIRA_PAT_TOKEN=

# Jira 사용자 ID (사번)
JIRA_USERNAME=
